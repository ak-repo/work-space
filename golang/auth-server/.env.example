# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-secret

# Token lifetimes (Go duration strings)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h   # 7 days

# ── Passwords ─────────────────────────────────────────────────────────────────
BCRYPT_COST=12           # 10–14; higher = safer but slower

# ── Social – Google ───────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Social – GitHub ───────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave blank to use the console sender (prints to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@yourapp.com
